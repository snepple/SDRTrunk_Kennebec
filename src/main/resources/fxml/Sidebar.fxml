<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.SVGPath?>

<VBox fx:id="root" alignment="TOP_LEFT" styleClass="kennebec-grouped-bg"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.dsheirer.gui.sidebar.SidebarController">

    <padding>
        <Insets top="8" right="8" bottom="8" left="8"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="8">
        <padding>
            <Insets bottom="4" left="2"/>
        </padding>
        <Button fx:id="toggleBtn" onAction="#handleToggle"
                accessibleText="Toggle Sidebar"
                styleClass="kennebec-toolbar-button"
                style="-fx-padding: 6;">
            <tooltip><Tooltip text="Toggle Sidebar"/></tooltip>
            <!-- Hamburger menu icon -->
            <graphic>
                <SVGPath content="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" />
            </graphic>
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </Button>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;">
        <VBox fx:id="menuContainer" spacing="2" alignment="TOP_LEFT">
            <!-- Items injected by controller -->
        </VBox>
    </ScrollPane>
</VBox>
