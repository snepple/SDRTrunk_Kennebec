<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.dsheirer.channel.details.ChannelDetailPanelController">
    <HBox spacing="10">
        <Label text="System:" />
        <Label fx:id="mSystemLabel" text=" " HBox.hgrow="ALWAYS" />
        <Label text="Site:" />
        <Label fx:id="mSiteLabel" text=" " HBox.hgrow="ALWAYS" />
        <Label text="Channel Name:" />
        <Label fx:id="mNameLabel" text=" " HBox.hgrow="ALWAYS" />
    </HBox>
    <TextArea fx:id="mDetailTextPane" editable="false" VBox.vgrow="ALWAYS" />
</VBox>
