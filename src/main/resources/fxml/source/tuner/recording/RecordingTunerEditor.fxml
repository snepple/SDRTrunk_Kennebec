<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.dsheirer.source.tuner.recording.RecordingTunerEditorController"
      spacing="8">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="100" maxWidth="100" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Tuner:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="tunerIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="tunerStatusLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="File:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="recordingPathLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" wrapText="true"/>

        <VBox fx:id="buttonPanelContainer" GridPane.columnIndex="1" GridPane.rowIndex="3" alignment="CENTER_LEFT" />
    </GridPane>

    <!-- Empty spacing (24px approx via spacing of VBox and empty Region/Label, here just add empty space) -->
    <javafx.scene.layout.Region minHeight="24" />

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="100" maxWidth="100" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Frequency (MHz):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <VBox fx:id="frequencyPanelContainer" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
    </GridPane>
</VBox>
