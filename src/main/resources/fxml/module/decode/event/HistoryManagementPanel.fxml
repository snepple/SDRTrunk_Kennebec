<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox fx:id="root" alignment="CENTER_LEFT" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.dsheirer.module.decode.event.HistoryManagementPanelController">
   <children>
      <Button fx:id="filterButton" mnemonicParsing="false" onAction="#handleFilterClick" text="Filter" />
      <Button fx:id="clearButton" mnemonicParsing="false" onAction="#handleClearClick" text="Clear" />
      <Region HBox.hgrow="ALWAYS" />
      <Label text="History Size:" />
      <Slider fx:id="historySlider" blockIncrement="500.0" majorTickUnit="500.0" max="2000.0" minorTickCount="0" onMouseClicked="#handleSliderMouseClicked" showTickLabels="true" showTickMarks="true" snapToTicks="true" />
      <Label fx:id="historyValueLabel" minWidth="40.0" text="0" />
   </children>
   <padding>
      <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
   </padding>
</HBox>
